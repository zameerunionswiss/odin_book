<% content_for :title, "Edit profile" %>

<div class="container py-5" style="max-width: 620px;">
  <div class="mb-4">
    <p class="text-muted small mb-1">Account settings</p>
    <h1 class="h4 fw-semibold mb-0">Edit profile</h1>
  </div>

  <div class="card border shadow-none">
    <div class="card-body p-4">
      <%= render "form", user: @user %>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mt-3">
    <div class="d-flex gap-3">
      <%= link_to "View profile", @user, class: "text-muted small text-decoration-none" %>
      <%= link_to "Back to users", users_path, class: "text-muted small text-decoration-none" %>
    </div>
  </div>
</div>