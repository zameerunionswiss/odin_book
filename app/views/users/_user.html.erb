<div id="<%= dom_id user %>">
  <p>
    <strong>Name:</strong>
    <%= user.name %>
  </p>
  <% if current_user.avatar.attached? %>
    <img id="avatar-preview" src="<% current_user.avatar %>" class="d-none mt-2 rounded-circle" width="100" height="100" style="object-fit: cover;" />
    <%= image_tag current_user.avatar, size: "100x100", alt:'/icon.png', style: "border-radius: 100%;" %>
  <% else %>
    <div class="border border-1 rounded-circle bg-success align-items-center align-content-center text-center" style="width: 4vw; height: 4vw">
      <%= @user.name.first.upcase %><%= @user.name.at(1).upcase %>
    </div>
  <% end %>

</div>