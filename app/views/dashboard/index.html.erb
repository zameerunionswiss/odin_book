
<body  style="display: flex; flex-direction: column">
<div id="top" style="position: relative" class="d-flex flex-column justify-content-between align-items-center border-bottom pb-3">
  <div class="d-flex align-items-center gap-2">
    <%= image_tag '/icon.png', size: "40x40", alt: "Logo" %>
    <span class="fw-bold fs-4">MyDashboard</span>
  </div>

</div>
<div id="content" class="d-flex flex-direction-row">

<div id="left" class="d-flex flex-row gap-3" style="flex: 1">
  <div class="card shadow-sm border-top">
    <div class="card-body d-flex flex-column gap-2">
      <h5 class="card-title fw-bold mb-2">Welcome back, <%= current_user.name %>!</h5>
      <p class="card-text text-muted">Here's a quick overview of your dashboard.</p>
      <div class="d-flex gap-2 mt-3">
        <%= link_to "View Profile", user_path(current_user), class: "btn btn-sm btn-outline-primary", data: { turbo_frame: "_top"} %>
        <%= link_to "Settings", edit_user_registration_path, class: "btn btn-sm btn-outline-secondary", data: { turbo_frame: "_top"} %>
        <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "btn btn-sm btn-outline-danger" %>
      </div>
    </div>
  </div>

</div> <!--end of left-->

<div id="middle" class="d-flex flex-column" style="flex: 2">

<%= turbo_stream_from "posts"%>
<div id="posts" class="d-flex flex-column gap-1">
  <% @posts.each do |post| %>
    <%= render post %>
    <p>
      <%#= link_to "Show this post", post, data: { turbo_frame: "_top"} %>
    </p>
  <% end %>
</div>

  <% if @pagy.next %>
    <%= turbo_frame_tag "load_more" do %>
      <%= link_to "Load More",
                  dashboard_path(page: @pagy.next),
                  data: {turbo_stream: true},
                  class: "btn btn-outline-primary" %>

    <% end %>

<% end %>


</div> <!--end of middle-->
<div id="right" class="d-flex flex-column border ms-5" style="flex: 1; ">
  <%= image_tag '/icon.png', size: "120x120", style: "margin-top: 9vh; margin-left: 30%; border-radius: 100%;"%>
  <p> Show something in this div Lets make this a description of some random thing before moving on to the next</p>

</div> <!--end of right-->
</div>
<div id="footer">
  This is my footer
</div>
</body>