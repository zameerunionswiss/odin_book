<p style="color: green"><%= notice %></p>

<%#= turbo_stream_from "posts"  %>
<br>
<% if @posts.any? %>


    <div class="row">
    <button data-controller="posts" data-action="click->posts#show" data-posts-url-value="<%= posts_path %>">
      <div  data-posts-target="posts"></div>
      <%= 'This is technically a button used for stimulus controller' %>
    </button>
    <%= render partial: "post", locals: { post: @posts.first } %>
  </div>

<div class="mb-5" style="border-width:10px; border-bottom-color: #B00100; margin-left: 10%; margin-right: 10%">
  <button data-controller="posts" data-posts-target="frame" data-action="click->posts#switch_partial" data-posts-url-value="<%= posts_path %>" style="top: 20px">
  <%= link_to "MaGiC button to switch the partial to comments section",  all_comments_path,  data:{turbo_frame: "post_ad"}%>
  </button>

  <%= link_to "Add a new Post",new_post_path, class: "btn btn-success" %>

</div>

  <%= render @posts %>

<% else %>
  <div class="text-center text-muted py-5">
    <p class="fs-5">No posts yet.</p>
    <%= link_to "Create your first post", new_post_path, class: "btn btn-primary mt-2" %>
  </div>
<% end %>

