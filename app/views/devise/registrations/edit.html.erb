<% content_for :title, "Edit profile" %>

<div class="container py-5" style="max-width: 620px;">
  <div class="mb-4">
    <p class="text-muted small mb-1">Account settings</p>
    <h1 class="h4 fw-semibold mb-0">Edit profile</h1>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "card border shadow-none" }) do |f| %>
    <div class="card-body p-4 d-flex flex-column gap-3">

      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "form-label small text-muted mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="form-text text-warning mt-1">Awaiting confirmation for: <strong><%= resource.unconfirmed_email %></strong></p>
        <% end %>
      </div>

      <hr class="my-1">
      <p class="small fw-semibold mb-0">Change password</p>

      <div>
        <%= f.label :password, class: "form-label small text-muted mb-1" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "Leave blank to keep current password" %>
        <% if @minimum_password_length %>
          <p class="form-text"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "form-label small text-muted mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
      </div>

      <hr class="my-1">

      <div>
        <%= f.label :current_password, class: "form-label small text-muted mb-1" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
        <p class="form-text">Required to confirm any changes above.</p>
      </div>

    </div>

    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center px-4 py-3">
      <%= link_to "Back", :back, class: "text-muted small text-decoration-none" %>
      <%= f.submit "Save changes", class: "btn btn-dark btn-sm px-4" %>
    </div>
  <% end %>

  <div class="mt-4 pt-3 border-top">
    <p class="small fw-semibold text-danger mb-1">Danger zone</p>
    <p class="small text-muted mb-2">Deleting your account is permanent and cannot be undone.</p>
    <%= button_to "Cancel my account",
                  registration_path(resource_name),
                  data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
                  method: :delete,
                  class: "btn btn-outline-danger btn-sm" %>
  </div>
</div>