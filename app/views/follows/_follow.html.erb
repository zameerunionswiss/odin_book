
<div class="container py-4">
  <% if followers.any? %>
    <div class="mb-4" style="width: 15vw; color: black; font-weight: bold"><%= @user.id == current_user.id ? "Your Followers" : @user.name + "'s Followers"  %></div>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% followers.each do |follower| %>
        <div class="col">
          <%= link_to user_path(follower), class: "text-decoration-none text-dark" do %>
            <div class="card h-100 shadow-sm">
              <div class="card-body d-flex align-items-center gap-3">
                <%= image_tag (follower.avatar.attached? ? follower.avatar : "/icon.png"),
                              class: "rounded-circle",
                              style: "width: 56px; height: 56px; object-fit: cover;",
                              alt: follower.name %>
                <span class="fw-semibold"><%= follower.name %></span>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

  <% else %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-people fs-1"></i>
      <p class="mt-3 mb-0">No followers yet.</p>
    </div>
  <% end %>
</div>